# Supabase Postgres — required for the backend (both local dev and Vercel)
# In Supabase: Project Settings > Database > Connection string (URI)
# Prefer the "Transaction pooler" string for serverless usage on Vercel.
#
# Copy this file to `backend/.env` and fill in your real value there
# (backend/.env is gitignored). Do NOT put real secrets in this file.
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Optional — CSV list of additional origins for CORS
# (defaults already include localhost:5173 and localhost:3000)
# ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app
