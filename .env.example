# Copy to backend/.env and fill in real values. Never commit real secrets.

# ─── Required ───
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ─── v3 Theme Radar (required for Theme Radar features) ───
# KIS Developers — https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=

# Anthropic Claude (Haiku for news classification)
ANTHROPIC_API_KEY=

# Random secret used to authenticate Vercel/GitHub Actions cron requests
CRON_SECRET=

# ─── Optional ───
# ALLOWED_ORIGINS=https://your-domain.vercel.app
